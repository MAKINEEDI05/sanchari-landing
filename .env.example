# ─────────────────────────────────────────────────────────────────────────────
# SMTP configuration for the contact / waitlist / investor forms.
# Used only by the serverless function in api/contact.ts (server-side).
# Copy this file to `.env` for local development (`vercel dev`) and set the same
# variables in Vercel → Project → Settings → Environment Variables for production.
# Never commit real credentials.
# ─────────────────────────────────────────────────────────────────────────────

# SMTP server host, e.g. smtp.gmail.com, smtp.zoho.in, email-smtp.<region>.amazonaws.com
SMTP_HOST=

# SMTP port: 587 for STARTTLS (recommended) or 465 for implicit TLS
SMTP_PORT=587

# Set to "true" only when using port 465 (implicit TLS). Otherwise "false".
SMTP_SECURE=false

# SMTP username and password (or app-specific password / API key)
SMTP_USER=
SMTP_PASS=

# "From" address shown on outgoing mail (often must match SMTP_USER's domain)
MAIL_FROM=

# Where form submissions are delivered
MAIL_TO=
