# ─────────────────────────────────────────────────────────────────────────────
# Email configuration for the contact / waitlist / investor forms.
# Used only by the serverless function in api/contact.ts (server-side).
# Copy this file to `.env` for local development (`vercel dev`) and set the same
# variables in Vercel → Project → Settings → Environment Variables for production.
# Never commit real credentials.
# ─────────────────────────────────────────────────────────────────────────────

# ── SMTP transport (credentials — keep secret) ──
# SMTP server host, e.g. smtp.zoho.in, smtp.gmail.com, email-smtp.<region>.amazonaws.com
SMTP_HOST=
# 587 for STARTTLS (recommended) or 465 for implicit TLS
SMTP_PORT=587
# "true" only when using port 465 (implicit TLS); otherwise "false"
SMTP_SECURE=false
# SMTP username and password (or app-specific password / API key)
SMTP_USER=
SMTP_PASS=

# ── Form routing (which address each form sends from / to) ──
# Waitlist form
CONTACT_FROM_EMAIL=contact@sanchari.me
CONTACT_TO_EMAIL=contact@sanchari.me
# Investor deck form
INVESTORS_FROM_EMAIL=investors@sanchari.me
INVESTORS_TO_EMAIL=investors@sanchari.me

# Public support address (reserved for a future support form). The address shown
# on the site itself is defined in src/config/company.ts.
SUPPORT_EMAIL=support@sanchari.me
